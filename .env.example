# Shopify App credentials (from Dev Dashboard > Settings > Credentials)
SHOPIFY_API_KEY=your_client_id_here
SHOPIFY_API_SECRET=your_client_secret_here
SHOPIFY_SCOPES=read_orders,write_orders,read_draft_orders,write_draft_orders

# Public URL of this server (ngrok tunnel URL during development)
HOST=https://your-tunnel.ngrok-free.app

# SATIM Payment Gateway credentials
SATIM_USERNAME=
SATIM_PASSWORD=
SATIM_TERMINAL_ID=
SATIM_TEST_MODE=true
SATIM_MOCK_MODE=false

# Server port (must differ from Next.js which runs on 3000)
PORT=3001
